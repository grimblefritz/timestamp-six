# ts6 deploy config for https://smisco.biz/ts6/
#
# ts6 ships ts6.php as a DOWNLOADABLE library file, not an executable page.
# The host installs a cPanel PHP handler for .php site-wide (AddHandler
# application/x-httpd-alt-phpNN .php). Under /ts6/ that would EXECUTE ts6.php
# instead of serving its source — and because the file only defines functions
# (no top-level output), execution returns a blank 0-byte page. ts6 has no
# server-side PHP to run; index.html is the only entry point. So we revert .php
# to the static file handler here and serve it as readable text. Applies
# recursively to files/{version}/ and src/ as well.
<FilesMatch "\.php$">
    SetHandler default-handler
    ForceType text/plain
</FilesMatch>
